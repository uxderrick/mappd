{
  "name": "mappd",
  "version": "0.1.9",
  "type": "module",
  "bin": {
    "mappd": "dist/index.js"
  },
  "files": [
    "dist",
    "canvas-dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "build:canvas": "cd ../canvas && npm run build && rm -rf ../cli/canvas-dist && cp -r dist ../cli/canvas-dist",
    "prepublishOnly": "npm run build:canvas && npm run build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.0",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "mappd-parser": "file:../parser",
    "picocolors": "^1.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "ws": "^8.16.0"
  }
}
